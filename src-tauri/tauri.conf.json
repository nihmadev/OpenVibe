{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "openvibe",
  "version": "0.1.0",
  "identifier": "com.openvibe.app",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "openvibe",
        "width": 1300,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "mas-macos", "app"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "files": {}
    }
  }
}
